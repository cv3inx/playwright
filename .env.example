# Copy to .env on the VPS and edit. docker-compose reads it automatically.

# Host port to bind. The container always listens on 7860 internally.
HOST_PORT=7860

# Per-request timeout in milliseconds. Default 30 minutes.
TIMEOUT_MS=1800000

# Resource caps for the container (tune to your VPS).
CPU_LIMIT=4.0
MEM_LIMIT=8g

# Optional — only set if you want stealth.solveTurnstileWithService() to work
# when the Turnstile checkbox click alone fails. Both are paid services.
# TWOCAPTCHA_KEY=
# CAPSOLVER_KEY=
